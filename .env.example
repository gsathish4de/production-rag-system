# ═══════════════════════════════════════════════════════════════════════════
# Production RAG System - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# Never commit .env to git (it's in .gitignore)

# ─── LLM & Embeddings ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_ORG_ID=  # Optional

# Model Selection
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1000

# ─── Vector Database (PostgreSQL + pgvector) ─────────────────────────────────
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DB=rag_system
PGVECTOR_USER=rag_user
PGVECTOR_PASSWORD=your_secure_password_here
PGVECTOR_SCHEMA=public

# Connection Pool
PGVECTOR_POOL_SIZE=5
PGVECTOR_MAX_OVERFLOW=10

# ─── Retrieval Configuration ─────────────────────────────────────────────────
# Vector search
RETRIEVAL_VECTOR_TOP_K=50
VECTOR_SIMILARITY_THRESHOLD=0.7

# BM25 search
RETRIEVAL_BM25_TOP_K=50

# Re-ranking
RERANK_TOP_K=5
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# RRF (Reciprocal Rank Fusion)
RRF_K=60

# ─── Chunking Strategy ───────────────────────────────────────────────────────
CHUNK_SIZE=512  # tokens
CHUNK_OVERLAP=51  # ~10% overlap
CHUNKING_STRATEGY=sentence_based  # sentence_based | fixed_size | semantic

# ─── Evaluation ──────────────────────────────────────────────────────────────
# RAGAS thresholds
RAGAS_FAITHFULNESS_THRESHOLD=0.8
RAGAS_ANSWER_RELEVANCY_THRESHOLD=0.75
RAGAS_CONTEXT_RELEVANCY_THRESHOLD=0.7

# Evaluation sampling
EVAL_SAMPLE_RATE=0.1  # Evaluate 10% of queries asynchronously
EVAL_DATASET_PATH=data/eval/golden_questions.json

# ─── Monitoring & Observability ──────────────────────────────────────────────
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json  # json | text

# Tracing (optional - uncomment to enable)
# LANGFUSE_PUBLIC_KEY=pk-xxx
# LANGFUSE_SECRET_KEY=sk-xxx
# LANGFUSE_HOST=https://cloud.langfuse.com
# ENABLE_TRACING=true

# Cost tracking
TRACK_COSTS=true
ALERT_DAILY_COST_THRESHOLD=100.0  # USD

# ─── Guardrails ──────────────────────────────────────────────────────────────
ENABLE_PII_DETECTION=true
ENABLE_PROMPT_INJECTION_CHECK=true
MAX_QUERY_LENGTH=2000  # characters

# ─── API Server ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false  # Set to true in development

# CORS
CORS_ORIGINS=["http://localhost:3000"]  # Adjust for your frontend

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # seconds

# ─── Storage ─────────────────────────────────────────────────────────────────
# Source documents
SOURCE_DOCS_PATH=data/sample_docs

# Output logs
LOGS_PATH=logs
EVAL_RESULTS_PATH=outputs/eval_results

# ─── Development ─────────────────────────────────────────────────────────────
ENVIRONMENT=development  # development | staging | production
DEBUG=false
